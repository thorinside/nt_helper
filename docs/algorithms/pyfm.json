{
  "guid": "pyfm",
  "name": "Poly FM",
  "description": "A polyphonic, multitimbral, FM synthesizer inspired by the original Poly FM algorithm on the disting EX. It uses the six-operator FM engine from the open source Plaits module by Émilie Gillet and loads Yamaha DX7 voice bank SysEx files from the MicroSD card.",
  "categories": [
    "Synthesis",
    "FM Synthesis",
    "Polysynth"
  ],
  "short_description": "A polyphonic FM synthesizer",
  "use_cases": [
    "FM synthesis",
    "Multitimbral sound design",
    "Yamaha DX7 voice loading"
  ],
  "gui_description": "The display shows the notes being played by the various voices, each superimposed on a bar to indicate the note envelope. When adjusting the microtuning parameters, more information about the chosen tuning is displayed.",
