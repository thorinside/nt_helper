{
  "guid": "phsh",
  "name": "Phase Shifter",
  "description": "This algorithm is based on the Phase Shifter algorithm on the disting mk4. It generates two outputs, one of which is in a fixed phase relationship to the other. Unlike the Phaser algorithm, which is simply designed to create a swooshy sound, this algorithm is designed for mathematical accuracy, and can produce some interesting psycho-acoustic effects. It can also produce swooshy sounds.",
  "categories": [
    "Audio Effects",
    "Phase Effects",
    "Psycho-acoustic"
  ],
  "short_description": "Shifts the phase of signals",
